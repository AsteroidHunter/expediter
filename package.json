{
	"name": "expediter",
	"private": true,
	"version": "0.73.0",
	"type": "module",
	"description": "Local-first ticket UI for Claude Code, driven by hook events from your active sessions.",
	"author": "AsteroidHunter (https://github.com/AsteroidHunter)",
	"license": "SEE LICENSE IN LICENSE",
	"homepage": "https://github.com/AsteroidHunter/expediter#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AsteroidHunter/expediter.git"
	},
	"bugs": {
		"url": "https://github.com/AsteroidHunter/expediter/issues"
	},
	"scripts": {
		"dev": "vite dev --host 0.0.0.0 --port 5179",
		"build": "vite build",
		"preview": "vite preview --host 0.0.0.0 --port 5179",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "bun test",
		"tether-ip": "node ./bin/tether-ip.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.7.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"qrcode-terminal": "^0.12.0"
	}
}
